  "semanticTokenColors": {
    "comment": {
      "foreground": "#A8ACC0",
      "italic": true
    },
    "variable": "#D7DAE3",
    "variable.readonly": "#FFE5B4",
    "variable.defaultLibrary": "#56B6C2",
    "parameter": "#BFC3D0",
    "property": "#5FA8B8",
    "function": "#6C82D9",
    "method": "#6C82D9",
    "class": "#B2A1FF",
    "interface": "#56B6C2",
    "enum": "#C25680",
    "enumMember": "#D05A8E",
    "type": "#B2A1FF",
    "decorator": "#C25680",
    "keyword": "#CFAE6A",
    "string": "#81D99A",
    "number": "#FFE5B4",
    "regexp": "#56B6C2",
    "namespace": "#56B6C2"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#A8ACC0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "string.unquoted.heredoc",
        "string.interpolated",
        "string.yaml",
        "string.sql"
      ],
      "settings": {
        "foreground": "#81D99A"
      }
    },
    {
      "name": "String Escapes and Regex",
      "scope": [
        "constant.character.escape",
        "string.regexp",
        "string.regexp punctuation.definition.string.begin",
        "string.regexp punctuation.definition.string.end"
      ],
      "settings": {
        "foreground": "#56B6C2"
      }
    },
    {
      "name": "Numbers and Constants",
      "scope": [
        "constant.numeric",
        "constant.language.boolean",
        "constant.language",
        "constant.character",
        "constant.other",
        "support.constant"
      ],
      "settings": {
        "foreground": "#FFE5B4"
      }
    },
    {
      "name": "Booleans",
      "scope": [
        "constant.language.boolean",
        "constant.bool",
        "keyword.other.unit"
      ],
      "settings": {
        "foreground": "#FFE5B4",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "meta.definition.variable",
        "meta.object-literal.key",
        "meta.mapping.key"
      ],
      "settings": {
        "foreground": "#D7DAE3"
      }
    },
    {
      "name": "Readonly and Builtin Variables",
      "scope": [
        "variable.other.constant",
        "variable.language",
        "support.variable"
      ],
      "settings": {
        "foreground": "#56B6C2"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter",
        "meta.function.parameters",
        "meta.parameter.object-pattern"
      ],
      "settings": {
        "foreground": "#BFC3D0"
      }
    },
    {
      "name": "Properties and Fields",
      "scope": [
        "variable.object.property",
        "variable.other.property",
        "support.type.property-name",
        "meta.object-literal.key",
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#5FA8B8"
      }
    },
    {
      "name": "Functions and Methods",
      "scope": [
        "entity.name.function",
        "support.function",
        "variable.function",
        "meta.function-call",
        "meta.method-call",
        "entity.name.method"
      ],
      "settings": {
        "foreground": "#6C82D9"
      }
    },
    {
      "name": "Keywords and Control Flow",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.declaration",
        "storage.modifier",
        "storage.type"
      ],
      "settings": {
        "foreground": "#CFAE6A"
      }
    },
    {
      "name": "Operators and Punctuation",
      "scope": [
        "keyword.operator",
        "punctuation.separator",
        "punctuation.accessor",
        "punctuation.definition.generic",
        "punctuation.definition.parameters",
        "punctuation.definition.typeparameters",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#BFC3D0"
      }
    },
    {
      "name": "Classes Interfaces Types Enums",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.interface",
        "entity.name.enum",
        "support.class",
        "support.type",
        "storage.type.class",
        "storage.type.interface",
        "storage.type.enum",
        "meta.type.identifier"
      ],
      "settings": {
        "foreground": "#B2A1FF"
      }
    },
    {
      "name": "Namespaces and Modules",
      "scope": [
        "entity.name.namespace",
        "entity.name.module",
        "support.module",
        "support.other.namespace",
        "meta.namespace"
      ],
      "settings": {
        "foreground": "#56B6C2"
      }
    },
    {
      "name": "Decorators and Attributes",
      "scope": [
        "meta.annotation",
        "storage.type.annotation",
        "entity.name.function.decorator",
        "entity.name.tag.decorator",
        "punctuation.definition.annotation"
      ],
      "settings": {
        "foreground": "#C25680"
      }
