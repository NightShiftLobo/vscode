  "semanticTokenColors": {
    "comment": {
      "foreground": "#969DAF",
      "italic": true
    },
    "variable": "#C7CBD7",
    "variable.readonly": "#B19861",
    "variable.defaultLibrary": "#45929A",
    "parameter": "#ADB3C1",
    "property": "#4F9EA4",
    "function": "#5569B2",
    "method": "#5569B2",
    "class": "#6376C2",
    "interface": "#45929A",
    "enum": "#954665",
    "enumMember": "#9E496D",
    "type": "#6376C2",
    "decorator": "#954665",
    "keyword": "#A38B56",
    "string": "#61A474",
    "number": "#B19861",
    "regexp": "#45929A",
    "namespace": "#45929A"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#969DAF",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "string.unquoted.heredoc",
        "string.interpolated",
        "string.yaml",
        "string.sql"
      ],
      "settings": {
        "foreground": "#61A474"
      }
    },
    {
      "name": "String Escapes and Regex",
      "scope": [
        "constant.character.escape",
        "string.regexp",
        "string.regexp punctuation.definition.string.begin",
        "string.regexp punctuation.definition.string.end"
      ],
      "settings": {
        "foreground": "#45929A"
      }
    },
    {
      "name": "Numbers and Constants",
      "scope": [
        "constant.numeric",
        "constant.language.boolean",
        "constant.language",
        "constant.character",
        "constant.other",
        "support.constant"
      ],
      "settings": {
        "foreground": "#B19861"
      }
    },
    {
      "name": "Booleans",
      "scope": [
        "constant.language.boolean",
        "constant.bool",
        "keyword.other.unit"
      ],
      "settings": {
        "foreground": "#B19861",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "meta.definition.variable",
        "meta.object-literal.key",
        "meta.mapping.key"
      ],
      "settings": {
        "foreground": "#C7CBD7"
      }
    },
    {
      "name": "Readonly and Builtin Variables",
      "scope": [
        "variable.other.constant",
        "variable.language",
        "support.variable"
      ],
      "settings": {
        "foreground": "#45929A"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter",
        "meta.function.parameters",
        "meta.parameter.object-pattern"
      ],
      "settings": {
        "foreground": "#ADB3C1"
      }
    },
    {
      "name": "Properties and Fields",
      "scope": [
        "variable.object.property",
        "variable.other.property",
        "support.type.property-name",
        "meta.object-literal.key",
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#4F9EA4"
      }
    },
    {
      "name": "Functions and Methods",
      "scope": [
        "entity.name.function",
        "support.function",
        "variable.function",
        "meta.function-call",
        "meta.method-call",
        "entity.name.method"
      ],
      "settings": {
        "foreground": "#5569B2"
      }
    },
    {
      "name": "Keywords and Control Flow",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.declaration",
        "storage.modifier",
        "storage.type"
      ],
      "settings": {
        "foreground": "#A38B56"
      }
    },
    {
      "name": "Operators and Punctuation",
      "scope": [
        "keyword.operator",
        "punctuation.separator",
        "punctuation.accessor",
        "punctuation.definition.generic",
        "punctuation.definition.parameters",
        "punctuation.definition.typeparameters",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#ADB3C1"
      }
    },
    {
      "name": "Classes Interfaces Types Enums",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.interface",
        "entity.name.enum",
        "support.class",
        "support.type",
        "storage.type.class",
        "storage.type.interface",
        "storage.type.enum",
        "meta.type.identifier"
      ],
      "settings": {
        "foreground": "#6376C2"
      }
    },
    {
      "name": "Namespaces and Modules",
      "scope": [
        "entity.name.namespace",
        "entity.name.module",
        "support.module",
        "support.other.namespace",
        "meta.namespace"
      ],
      "settings": {
        "foreground": "#45929A"
      }
    },
    {
      "name": "Decorators and Attributes",
      "scope": [
        "meta.annotation",
        "storage.type.annotation",
        "entity.name.function.decorator",
        "entity.name.tag.decorator",
        "punctuation.definition.annotation"
      ],
      "settings": {
        "foreground": "#954665"
      }
    },
    {
      "name": "Generics and Type Parameters",
      "scope": [
        "entity.name.type.parameter",
        "meta.type.parameters",
        "support.type.generic"
      ],
      "settings": {
        "foreground": "#45929A"
      }
    },
    {
      "name": "HTML Tags",
      "scope": [
        "entity.name.tag",
        "meta.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#5569B2"
      }
    },
    {
      "name": "HTML Attributes",
