        "keyword.operator.or.regexp",
        "constant.other.character-class.set.regexp"
      ],
      "settings": { "foreground": "#B86A8C" }
    },

    {
      "name": "XML Tag Names",
      "scope": ["entity.name.tag", "entity.name.tag.xml", "meta.tag", "meta.tag.preprocessor"],
      "settings": { "foreground": "#5C73D8" }
    },
    {
      "name": "XML Attributes",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#4C9AA5" }
    },
    {
      "name": "XML Attribute Values",
      "scope": ["string.quoted.double.xml", "string.quoted.single.xml"],
      "settings": { "foreground": "#5EA87C" }
    },
    {
      "name": "XML Brackets and Separators",
      "scope": [
