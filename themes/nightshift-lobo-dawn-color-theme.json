  "_comment.semanticTokenColors": "Semantic tokens tuned for structural clarity with calm accents.",
  "semanticTokenColors": {
    "variable": "#2E3440",
    "variable.readonly": "#B48C42",
    "variable.defaultLibrary": "#3F8F95",
    "variable.readonly.defaultLibrary": "#B48C42",
    "parameter": "#4C5568",
    "property": "#4F949A",
    "function": "#4F6EDB",
    "method": "#4F6EDB",
    "class": "#7A63B8",
    "interface": "#3F8F95",
    "enum": "#7A63B8",
    "enumMember": "#7A63B8",
    "type": "#7A63B8",
    "typeParameter": "#3F8F95",
    "decorator": "#7A63B8",
    "namespace": "#3F8F95",
    "module": "#4F949A",
    "struct": "#7A63B8",
    "boolean": "#B48C42",
    "number": "#B87A52",
    "selfKeyword": "#3F8F95",
    "heading": "#4F6EDB",
    "text.strong": {
      "foreground": "#2E3440",
      "bold": true
    },
    "text.emph": {
      "foreground": "#4C5568",
      "italic": true
    },
    "text.math": "#7A63B8",
    "tomlTableKey": "#4F949A",
    "tomlArrayKey": "#4F949A",
    "function.decorator:python": "#7A63B8",
    "class:python": "#7A63B8",
    "class.builtin:python": "#7A63B8",
    "type.defaultLibrary:go": "#3F8F95",
    "variable.typeHint:python": "#7A63B8",
    "comment": {
      "foreground": "#7A8194",
      "italic": true
    }
  },

  "_comment.tokenColors": "TextMate scopes for XML, Markdown, YAML, JSON, frontmatter, and embedded code blocks.",
  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment", "comment.block.xml"],
      "settings": { "foreground": "#7A8194", "fontStyle": "italic" }
    },
    {
      "name": "Strings",
      "scope": ["string", "string.quoted", "string.template", "string.yaml", "string.sql"],
      "settings": { "foreground": "#4F9C69" }
    },
    {
      "name": "Constants and Numbers",
      "scope": [
        "constant",
        "constant.numeric",
        "constant.language",
        "constant.character",
        "support.constant",
        "constant.numeric.yaml",
        "constant.numeric.json"
      ],
      "settings": { "foreground": "#B87A52" }
    },
    {
      "name": "Booleans",
      "scope": ["constant.language.boolean", "constant.bool", "constant.language.boolean.yaml"],
      "settings": { "foreground": "#B48C42", "fontStyle": "bold" }
    },
    {
      "name": "Variables",
      "scope": ["variable", "variable.other"],
      "settings": { "foreground": "#2E3440" }
    },
    {
      "name": "Parameters",
      "scope": ["variable.parameter", "meta.function.parameters"],
      "settings": { "foreground": "#4C5568" }
    },
    {
      "name": "Properties and Fields",
      "scope": [
        "variable.other.property",
        "variable.object.property",
        "support.type.property-name",
        "meta.object-literal.key"
      ],
      "settings": { "foreground": "#4F949A" }
    },
    {
      "name": "Functions and Methods",
      "scope": ["entity.name.function", "entity.name.method", "support.function", "meta.function-call", "meta.method-call"],
      "settings": { "foreground": "#4F6EDB", "fontStyle": "italic" }
    },
    {
      "name": "Keywords and Control Flow",
      "scope": ["keyword", "keyword.control", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#B48C42", "fontStyle": "bold" }
    },
    {
      "name": "Operators and Delimiters",
      "scope": ["keyword.operator", "punctuation.separator", "punctuation.accessor", "punctuation.separator.key-value"],
      "settings": { "foreground": "#6C7385" }
    },
    {
      "name": "Types Classes Interfaces Enums",
      "scope": ["entity.name.type", "entity.name.class", "entity.name.interface", "entity.name.enum", "support.type", "support.class"],
      "settings": { "foreground": "#7A63B8", "fontStyle": "bold" }
    },
    {
      "name": "Namespaces and Modules",
      "scope": ["entity.name.namespace", "entity.name.module", "support.module"],
      "settings": { "foreground": "#3F8F95" }
    },
    {
      "name": "Decorators",
      "scope": ["meta.annotation", "storage.type.annotation", "entity.name.function.decorator", "punctuation.definition.annotation"],
      "settings": { "foreground": "#7A63B8", "fontStyle": "italic" }
    },
    {
      "name": "Regex and Escapes",
      "scope": ["string.regexp", "constant.character.escape"],
      "settings": { "foreground": "#3F8F95" }
    },
    {
      "name": "Built-ins and Preprocessor",
      "scope": [
        "support.function.builtin",
        "support.class.builtin",
        "support.type.builtin",
        "entity.name.type.module",
        "entity.other.inherited-class",
        "meta.preprocessor",
        "keyword.control.import",
        "meta.import"
      ],
      "settings": { "foreground": "#3F8F95" }
    },
    {
      "name": "Type Parameters and Generics",
      "scope": [
        "entity.name.type.parameter",
        "meta.type.parameters",
        "support.type.generic",
        "punctuation.definition.typeparameters",
        "punctuation.definition.generic"
      ],
      "settings": { "foreground": "#7A63B8" }
    },
    {
      "name": "This Self Keyword",
      "scope": ["variable.language.this", "variable.language.self", "variable.language.special.self", "variable.language"],
      "settings": { "foreground": "#3F8F95" }
    },
    {
      "name": "Template String Interpolation",
      "scope": [
        "punctuation.definition.template-expression",
        "meta.template.expression",
        "string.interpolated variable"
      ],
      "settings": { "foreground": "#4C5568" }
    },
    {
      "name": "New Keyword and Arrow",
      "scope": ["keyword.operator.new", "storage.type.function.arrow", "punctuation.definition.arrow"],
      "settings": { "foreground": "#B48C42", "fontStyle": "bold" }
    },
    {
      "name": "JSDoc and Doc Keywords",
      "scope": [
        "storage.type.class.jsdoc",
        "entity.name.type.instance.jsdoc",
        "variable.other.jsdoc",
        "punctuation.definition.block.tag.jsdoc",
        "keyword.other.documentation"
      ],
      "settings": { "foreground": "#6C7385" }
    },
    {
      "name": "CSS Pseudo and Variables",
      "scope": [
        "entity.other.attribute-name.pseudo-class.css",
        "entity.other.attribute-name.pseudo-element.css",
        "variable.css",
        "variable.scss",
        "variable.sass",
        "support.type.vendored.property-name"
      ],
      "settings": { "foreground": "#3F8F95" }
    },
    {
      "name": "CSS Percentage and Attribute Selectors",
      "scope": [
        "constant.numeric.css",
        "constant.numeric.percentage.css",
        "meta.attribute-selector.css",
        "string.quoted.attribute-selector.css"
      ],
      "settings": { "foreground": "#B87A52" }
    },
    {
      "name": "YAML/JSON Constants and Anchors",
      "scope": [
        "constant.language.yaml",
        "constant.language.json",
        "variable.other.alias.yaml",
        "entity.name.type.anchor.yaml",
        "punctuation.definition.anchor.yaml"
      ],
      "settings": { "foreground": "#B48C42" }
    },
    {
      "name": "YAML Frontmatter Delimiters",
      "scope": [
        "punctuation.definition.metadata.markdown",
        "punctuation.definition.frontmatter",
        "entity.other.front-matter",
        "punctuation.separator.frontmatter"
      ],
      "settings": { "foreground": "#6C7385" }
    },
    {
      "name": "TOML Tables and Dates",
      "scope": [
        "entity.name.section.table.toml",
        "entity.name.section.group-title.toml",
        "keyword.key.toml",
        "support.type.property-name.toml",
        "constant.other.date.toml"
      ],
      "settings": { "foreground": "#4F949A" }
    },
    {
      "name": "Diff Markup",
      "scope": [
        "markup.inserted",
        "markup.deleted",
        "markup.changed",
        "meta.diff.header",
        "punctuation.definition.inserted",
        "punctuation.definition.deleted"
      ],
      "settings": { "foreground": "#6C7385" }
    },
    {
      "name": "Comment Keywords",
      "scope": [
        "comment keyword",
        "comment.other.todo",
        "keyword.codetag.notation",
        "storage.type.class.todo"
      ],
      "settings": { "foreground": "#B87A52", "fontStyle": "bold" }
    },
    {
      "name": "HTML Entities and Components",
      "scope": [
        "constant.character.entity",
        "punctuation.definition.entity",
        "support.class.component",
        "entity.name.tag.custom"
      ],
      "settings": { "foreground": "#7A63B8" }
    },
    {
      "name": "Markdown Auto Links and Raw Code",
      "scope": [
        "markup.underline.link.markdown",
        "meta.link.inline.markdown",
        "markup.inline.raw.string.markdown",
        "markup.raw.block"
      ],
      "settings": { "foreground": "#3F8F95" }
    },
    {
      "name": "Markdown Fence Language and Separators",
      "scope": [
        "fenced_code.block.language",
        "variable.language.fenced.markdown",
        "meta.separator.markdown",
        "punctuation.definition.hr.markdown"
      ],
      "settings": { "foreground": "#6C7385" }
    },
    {
      "name": "Python Specific",
      "scope": [
        "support.function.builtin.python",
        "support.type.python",
        "meta.function.decorator.python",
        "keyword.control.flow.python",
        "constant.language.python"
      ],
      "settings": { "foreground": "#4F6EDB" }
    },
    {
      "name": "Python Self and Type Hints",
      "scope": [
        "variable.parameter.function.language.special.self.python",
        "meta.function.parameters.python variable.parameter.type-hint.python",
        "meta.typehint.python"
      ],
      "settings": { "foreground": "#7A63B8" }
    },
    {
      "name": "Rust Specific",
      "scope": [
        "storage.type.attribute.rust",
        "entity.name.type.trait.rust",
        "entity.name.type.struct.rust",
        "entity.name.type.enum.rust",
        "entity.name.macro.rust",
        "support.type.rust"
      ],
      "settings": { "foreground": "#7A63B8" }
    },
    {
      "name": "Rust Lifetimes and Format",
      "scope": [
        "storage.modifier.lifetime.rust",
        "punctuation.definition.lifetime.rust",
        "constant.other.placeholder.rust"
      ],
      "settings": { "foreground": "#7A63B8" }
    },
    {
      "name": "Shell Specific",
      "scope": [
        "meta.shebang.shell",
        "support.function.builtin.shell",
        "meta.function-call.shell",
        "meta.interpolation.parameter.shell",
        "variable.parameter.normal.shell"
      ],
      "settings": { "foreground": "#3F8F95" }
    },
    {
      "name": "Regex Detailed",
      "scope": [
        "punctuation.definition.group.regexp",
