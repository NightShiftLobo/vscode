  "semanticTokenColors": {
    "comment": {
      "foreground": "#9CA2B6",
      "italic": true
    },
    "variable": "#CDD1DC",
    "variable.readonly": "#C2A96A",
    "variable.defaultLibrary": "#4DA2AD",
    "parameter": "#B2B7C5",
    "property": "#58B2B8",
    "function": "#6176C6",
    "method": "#6176C6",
    "class": "#6F84D6",
    "interface": "#4DA2AD",
    "enum": "#AA4D71",
    "enumMember": "#B2527A",
    "type": "#6F84D6",
    "decorator": "#AA4D71",
    "keyword": "#B49A5F",
    "string": "#6BB684",
    "number": "#C2A96A",
    "regexp": "#4DA2AD",
    "namespace": "#4DA2AD"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#9CA2B6",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "string.unquoted.heredoc",
        "string.interpolated",
        "string.yaml",
        "string.sql"
      ],
      "settings": {
        "foreground": "#6BB684"
      }
    },
    {
      "name": "String Escapes and Regex",
      "scope": [
        "constant.character.escape",
        "string.regexp",
        "string.regexp punctuation.definition.string.begin",
        "string.regexp punctuation.definition.string.end"
      ],
      "settings": {
        "foreground": "#4DA2AD"
      }
    },
    {
      "name": "Numbers and Constants",
      "scope": [
        "constant.numeric",
        "constant.language.boolean",
        "constant.language",
        "constant.character",
        "constant.other",
        "support.constant"
      ],
      "settings": {
        "foreground": "#C2A96A"
      }
    },
    {
      "name": "Booleans",
      "scope": [
        "constant.language.boolean",
        "constant.bool",
        "keyword.other.unit"
      ],
      "settings": {
        "foreground": "#C2A96A",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "meta.definition.variable",
        "meta.object-literal.key",
        "meta.mapping.key"
      ],
      "settings": {
        "foreground": "#CDD1DC"
      }
    },
    {
      "name": "Readonly and Builtin Variables",
      "scope": [
        "variable.other.constant",
        "variable.language",
        "support.variable"
      ],
      "settings": {
        "foreground": "#4DA2AD"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter",
        "meta.function.parameters",
        "meta.parameter.object-pattern"
      ],
      "settings": {
        "foreground": "#B2B7C5"
      }
    },
    {
      "name": "Properties and Fields",
      "scope": [
        "variable.object.property",
        "variable.other.property",
        "support.type.property-name",
        "meta.object-literal.key",
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#58B2B8"
      }
    },
    {
      "name": "Functions and Methods",
      "scope": [
        "entity.name.function",
        "support.function",
        "variable.function",
        "meta.function-call",
        "meta.method-call",
        "entity.name.method"
      ],
      "settings": {
        "foreground": "#6176C6"
      }
    },
    {
      "name": "Keywords and Control Flow",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.declaration",
        "storage.modifier",
        "storage.type"
      ],
      "settings": {
        "foreground": "#B49A5F"
      }
    },
    {
      "name": "Operators and Punctuation",
      "scope": [
        "keyword.operator",
        "punctuation.separator",
        "punctuation.accessor",
        "punctuation.definition.generic",
        "punctuation.definition.parameters",
        "punctuation.definition.typeparameters",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#B2B7C5"
      }
    },
    {
      "name": "Classes Interfaces Types Enums",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.interface",
        "entity.name.enum",
        "support.class",
        "support.type",
        "storage.type.class",
        "storage.type.interface",
        "storage.type.enum",
        "meta.type.identifier"
      ],
      "settings": {
        "foreground": "#6F84D6"
      }
    },
    {
      "name": "Namespaces and Modules",
      "scope": [
        "entity.name.namespace",
        "entity.name.module",
        "support.module",
        "support.other.namespace",
        "meta.namespace"
      ],
      "settings": {
        "foreground": "#4DA2AD"
      }
    },
    {
      "name": "Decorators and Attributes",
      "scope": [
        "meta.annotation",
        "storage.type.annotation",
        "entity.name.function.decorator",
        "entity.name.tag.decorator",
        "punctuation.definition.annotation"
      ],
      "settings": {
        "foreground": "#AA4D71"
      }
    },
    {
      "name": "Generics and Type Parameters",
      "scope": [
        "entity.name.type.parameter",
        "meta.type.parameters",
        "support.type.generic"
      ],
      "settings": {
        "foreground": "#4DA2AD"
      }
    },
    {
      "name": "HTML Tags",
      "scope": [
        "entity.name.tag",
