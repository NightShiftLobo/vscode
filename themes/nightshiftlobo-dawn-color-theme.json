  "semanticTokenColors": {
    "comment": {
      "foreground": "#717892",
      "italic": true
    },
    "variable": "#444A63",
    "variable.readonly": "#B79A69",
    "variable.defaultLibrary": "#4F93A3",
    "parameter": "#565D76",
    "property": "#60A5B2",
    "function": {
      "foreground": "#5B6FC8",
      "italic": true
    },
    "method": {
      "foreground": "#5B6FC8",
      "italic": true
    },
    "class": "#8B6594",
    "interface": "#4F93A3",
    "enum": "#8B6594",
    "enumMember": "#9E708E",
    "type": {
      "foreground": "#8B6594",
      "bold": true
    },
    "decorator": {
      "foreground": "#9E708E",
      "italic": true
    },
    "keyword": {
      "foreground": "#A88E5F",
      "bold": true
    },
    "string": "#7FA786",
    "number": "#B79A69",
    "regexp": "#4F93A3",
    "namespace": "#4F93A3"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#717892",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "string.unquoted.heredoc",
        "string.interpolated",
        "string.yaml",
        "string.sql"
      ],
      "settings": {
        "foreground": "#7FA786"
      }
    },
    {
      "name": "String Escapes and Regex",
      "scope": [
        "constant.character.escape",
        "string.regexp",
        "string.regexp punctuation.definition.string.begin",
        "string.regexp punctuation.definition.string.end"
      ],
      "settings": {
        "foreground": "#4F93A3"
      }
    },
    {
      "name": "Numbers and Constants",
      "scope": [
        "constant.numeric",
        "constant.language.boolean",
        "constant.language",
        "constant.character",
        "constant.other",
        "support.constant"
      ],
      "settings": {
        "foreground": "#B79A69"
      }
    },
    {
      "name": "Booleans",
      "scope": [
        "constant.language.boolean",
        "constant.bool",
        "keyword.other.unit"
      ],
      "settings": {
        "foreground": "#B79A69",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "meta.definition.variable",
        "meta.object-literal.key",
        "meta.mapping.key"
      ],
      "settings": {
        "foreground": "#444A63"
      }
    },
    {
      "name": "Readonly and Builtin Variables",
      "scope": [
        "variable.other.constant",
        "variable.language",
        "support.variable"
      ],
      "settings": {
        "foreground": "#4F93A3"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter",
        "meta.function.parameters",
        "meta.parameter.object-pattern"
      ],
      "settings": {
        "foreground": "#565D76"
      }
    },
    {
      "name": "Properties and Fields",
      "scope": [
        "variable.object.property",
        "variable.other.property",
        "support.type.property-name",
        "meta.object-literal.key",
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#60A5B2"
      }
    },
    {
      "name": "Functions and Methods",
      "scope": [
        "entity.name.function",
        "support.function",
        "variable.function",
        "meta.function-call",
        "meta.method-call",
        "entity.name.method"
      ],
      "settings": {
        "foreground": "#5B6FC8",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keywords and Control Flow",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.declaration",
        "storage.modifier",
        "storage.type"
      ],
      "settings": {
        "foreground": "#A88E5F",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Operators and Punctuation",
      "scope": [
        "keyword.operator",
        "punctuation.separator",
        "punctuation.accessor",
        "punctuation.definition.generic",
        "punctuation.definition.parameters",
        "punctuation.definition.typeparameters",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#565D76"
      }
    },
    {
      "name": "Classes Interfaces Types Enums",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.interface",
        "entity.name.enum",
        "support.class",
        "support.type",
        "storage.type.class",
        "storage.type.interface",
        "storage.type.enum",
        "meta.type.identifier"
      ],
      "settings": {
        "foreground": "#8B6594",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Namespaces and Modules",
      "scope": [
        "entity.name.namespace",
        "entity.name.module",
        "support.module",
        "support.other.namespace",
